{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1cVYcCPKZQp6RiEur0Y3CrkP_4-BGVxdD","timestamp":1782319977324}]},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":959},"id":"FajzCOCt-y1l","executionInfo":{"status":"ok","timestamp":1779379661554,"user_tz":240,"elapsed":35355,"user":{"displayName":"Cesar Tobar","userId":"15392823103327952578"}},"outputId":"c6d7d9aa-a4f0-4872-8248-292bf8e848f9"},"outputs":[{"output_type":"stream","name":"stdout","text":["Collecting pdfplumber\n","  Downloading pdfplumber-0.11.9-py3-none-any.whl.metadata (43 kB)\n","\u001b[?25l     \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m0.0/43.6 kB\u001b[0m \u001b[31m?\u001b[0m eta \u001b[36m-:--:--\u001b[0m\r\u001b[2K     \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m43.6/43.6 kB\u001b[0m \u001b[31m2.1 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hRequirement already satisfied: pandas in /usr/local/lib/python3.12/dist-packages (2.2.2)\n","Requirement already satisfied: openpyxl in /usr/local/lib/python3.12/dist-packages (3.1.5)\n","Collecting pdfminer.six==20251230 (from pdfplumber)\n","  Downloading pdfminer_six-20251230-py3-none-any.whl.metadata (4.3 kB)\n","Requirement already satisfied: Pillow>=9.1 in /usr/local/lib/python3.12/dist-packages (from pdfplumber) (11.3.0)\n","Collecting pypdfium2>=4.18.0 (from pdfplumber)\n","  Downloading pypdfium2-5.8.0-py3-none-manylinux_2_17_x86_64.manylinux2014_x86_64.whl.metadata (68 kB)\n","\u001b[2K     \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m68.4/68.4 kB\u001b[0m \u001b[31m2.9 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hRequirement already satisfied: charset-normalizer>=2.0.0 in /usr/local/lib/python3.12/dist-packages (from pdfminer.six==20251230->pdfplumber) (3.4.7)\n","Requirement already satisfied: cryptography>=36.0.0 in /usr/local/lib/python3.12/dist-packages (from pdfminer.six==20251230->pdfplumber) (43.0.3)\n","Requirement already satisfied: numpy>=1.26.0 in /usr/local/lib/python3.12/dist-packages (from pandas) (2.0.2)\n","Requirement already satisfied: python-dateutil>=2.8.2 in /usr/local/lib/python3.12/dist-packages (from pandas) (2.9.0.post0)\n","Requirement already satisfied: pytz>=2020.1 in /usr/local/lib/python3.12/dist-packages (from pandas) (2025.2)\n","Requirement already satisfied: tzdata>=2022.7 in /usr/local/lib/python3.12/dist-packages (from pandas) (2026.1)\n","Requirement already satisfied: et-xmlfile in /usr/local/lib/python3.12/dist-packages (from openpyxl) (2.0.0)\n","Requirement already satisfied: six>=1.5 in /usr/local/lib/python3.12/dist-packages (from python-dateutil>=2.8.2->pandas) (1.17.0)\n","Requirement already satisfied: cffi>=1.12 in /usr/local/lib/python3.12/dist-packages (from cryptography>=36.0.0->pdfminer.six==20251230->pdfplumber) (2.0.0)\n","Requirement already satisfied: pycparser in /usr/local/lib/python3.12/dist-packages (from cffi>=1.12->cryptography>=36.0.0->pdfminer.six==20251230->pdfplumber) (3.0)\n","Downloading pdfplumber-0.11.9-py3-none-any.whl (60 kB)\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m60.0/60.0 kB\u001b[0m \u001b[31m2.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hDownloading pdfminer_six-20251230-py3-none-any.whl (6.6 MB)\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m6.6/6.6 MB\u001b[0m \u001b[31m46.7 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hDownloading pypdfium2-5.8.0-py3-none-manylinux_2_17_x86_64.manylinux2014_x86_64.whl (3.7 MB)\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m3.7/3.7 MB\u001b[0m \u001b[31m48.1 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hInstalling collected packages: pypdfium2, pdfminer.six, pdfplumber\n","Successfully installed pdfminer.six-20251230 pdfplumber-0.11.9 pypdfium2-5.8.0\n","Please upload your PDF file.\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","     <input type=\"file\" id=\"files-f93298e7-161a-4900-9d0f-b1778cf8de61\" name=\"files[]\" multiple disabled\n","        style=\"border:none\" />\n","     <output id=\"result-f93298e7-161a-4900-9d0f-b1778cf8de61\">\n","      Upload widget is only available when the cell has been executed in the\n","      current browser session. Please rerun this cell to enable.\n","      </output>\n","      <script>// Copyright 2017 Google LLC\n","//\n","// Licensed under the Apache License, Version 2.0 (the \"License\");\n","// you may not use this file except in compliance with the License.\n","// You may obtain a copy of the License at\n","//\n","//      http://www.apache.org/licenses/LICENSE-2.0\n","//\n","// Unless required by applicable law or agreed to in writing, software\n","// distributed under the License is distributed on an \"AS IS\" BASIS,\n","// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n","// See the License for the specific language governing permissions and\n","// limitations under the License.\n","\n","/**\n"," * @fileoverview Helpers for google.colab Python module.\n"," */\n","(function(scope) {\n","function span(text, styleAttributes = {}) {\n","  const element = document.createElement('span');\n","  element.textContent = text;\n","  for (const key of Object.keys(styleAttributes)) {\n","    element.style[key] = styleAttributes[key];\n","  }\n","  return element;\n","}\n","\n","// Max number of bytes which will be uploaded at a time.\n","const MAX_PAYLOAD_SIZE = 100 * 1024;\n","\n","function _uploadFiles(inputId, outputId) {\n","  const steps = uploadFilesStep(inputId, outputId);\n","  const outputElement = document.getElementById(outputId);\n","  // Cache steps on the outputElement to make it available for the next call\n","  // to uploadFilesContinue from Python.\n","  outputElement.steps = steps;\n","\n","  return _uploadFilesContinue(outputId);\n","}\n","\n","// This is roughly an async generator (not supported in the browser yet),\n","// where there are multiple asynchronous steps and the Python side is going\n","// to poll for completion of each step.\n","// This uses a Promise to block the python side on completion of each step,\n","// then passes the result of the previous step as the input to the next step.\n","function _uploadFilesContinue(outputId) {\n","  const outputElement = document.getElementById(outputId);\n","  const steps = outputElement.steps;\n","\n","  const next = steps.next(outputElement.lastPromiseValue);\n","  return Promise.resolve(next.value.promise).then((value) => {\n","    // Cache the last promise value to make it available to the next\n","    // step of the generator.\n","    outputElement.lastPromiseValue = value;\n","    return next.value.response;\n","  });\n","}\n","\n","/**\n"," * Generator function which is called between each async step of the upload\n"," * process.\n"," * @param {string} inputId Element ID of the input file picker element.\n"," * @param {string} outputId Element ID of the output display.\n"," * @return {!Iterable<!Object>} Iterable of next steps.\n"," */\n","function* uploadFilesStep(inputId, outputId) {\n","  const inputElement = document.getElementById(inputId);\n","  inputElement.disabled = false;\n","\n","  const outputElement = document.getElementById(outputId);\n","  outputElement.innerHTML = '';\n","\n","  const pickedPromise = new Promise((resolve) => {\n","    inputElement.addEventListener('change', (e) => {\n","      resolve(e.target.files);\n","    });\n","  });\n","\n","  const cancel = document.createElement('button');\n","  inputElement.parentElement.appendChild(cancel);\n","  cancel.textContent = 'Cancel upload';\n","  const cancelPromise = new Promise((resolve) => {\n","    cancel.onclick = () => {\n","      resolve(null);\n","    };\n","  });\n","\n","  // Wait for the user to pick the files.\n","  const files = yield {\n","    promise: Promise.race([pickedPromise, cancelPromise]),\n","    response: {\n","      action: 'starting',\n","    }\n","  };\n","\n","  cancel.remove();\n","\n","  // Disable the input element since further picks are not allowed.\n","  inputElement.disabled = true;\n","\n","  if (!files) {\n","    return {\n","      response: {\n","        action: 'complete',\n","      }\n","    };\n","  }\n","\n","  for (const file of files) {\n","    const li = document.createElement('li');\n","    li.append(span(file.name, {fontWeight: 'bold'}));\n","    li.append(span(\n","        `(${file.type || 'n/a'}) - ${file.size} bytes, ` +\n","        `last modified: ${\n","            file.lastModifiedDate ? file.lastModifiedDate.toLocaleDateString() :\n","                                    'n/a'} - `));\n","    const percent = span('0% done');\n","    li.appendChild(percent);\n","\n","    outputElement.appendChild(li);\n","\n","    const fileDataPromise = new Promise((resolve) => {\n","      const reader = new FileReader();\n","      reader.onload = (e) => {\n","        resolve(e.target.result);\n","      };\n","      reader.readAsArrayBuffer(file);\n","    });\n","    // Wait for the data to be ready.\n","    let fileData = yield {\n","      promise: fileDataPromise,\n","      response: {\n","        action: 'continue',\n","      }\n","    };\n","\n","    // Use a chunked sending to avoid message size limits. See b/62115660.\n","    let position = 0;\n","    do {\n","      const length = Math.min(fileData.byteLength - position, MAX_PAYLOAD_SIZE);\n","      const chunk = new Uint8Array(fileData, position, length);\n","      position += length;\n","\n","      const base64 = btoa(String.fromCharCode.apply(null, chunk));\n","      yield {\n","        response: {\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.google.colab || {};\n","scope.google.colab._files = {\n","  _uploadFiles,\n","  _uploadFilesContinue,\n","};\n","})(self);\n","</script> "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saving DBL ORLANDO 91489094.pdf to DBL ORLANDO 91489094.pdf\n","\n","Processing 'DBL ORLANDO 91489094.pdf'...\n","Successfully extracted text from PDF. Total length: 2237 characters.\n","INFO: Detected Layout 2 (English/Other - based on 'List Price' keyword).\n","\n","--- Starting to parse using Layout 2 ('List Price' based) ---\n","--- Finished parsing with Layout 2. Found 5 items. ---\n","\n","Successfully parsed 5 items from PDF.\n","\n","--- Parsed Data Preview (First 5 rows) ---\n","           Style    Serial                                                                                                                                                                                                                                                                                                             Description  List Price  Quantity  Unit Price  Total Amount\n","0  AB3112241B1A1  20065164                                                                                                      SUPEROCEAN HERITAGE B31 6800.00 1 4,216.00 4,216.00 AUTOMATIC 44 cal. Chronometer B31, 12 1/2, 24J steel case, black ceramic ring, crystal back Black, markers OCEAN CLASSIC bracelet, steel Caliber : B31 , BCA01      6800.0         1      4216.0        4216.0\n","1  AB0137241L1A1  20055992                                                                                              NAVITIMER B01 CHRONOGRAPH 46 10700.00 1 6,634.00 6,634.00 cal. Chronometer B01, 13 1/4''', 47J steel case, black inside-bezel, crystal back Green, black subdials, markers NAVITIMER bracelet, steel Caliber : B01 , BCA01     10700.0         1      6634.0        6634.0\n","2  AB0137211B1A1  20013921                                                                                            NAVITIMER B01 CHRONOGRAPH 46 10700.00 1 6,634.00 6,634.00 cal. Chronometer B01, 13 1/4''', 47J steel case, silver inside-bezel, crystal back Black, silver subdials, markers NAVITIMER bracelet, steel Caliber : B01 , BCA01     10700.0         1      6634.0        6634.0\n","3  AB0139211L1P1  20113575                                                           NAVITIMER B01 CHRONOGRAPH 41 10300.00 1 6,386.00 6,386.00 cal. Chronometer B01, 13 1/4''', 47J steel case, silver inside-bezel, crystal back Mint green, silver subdials, markers full grain alligator strap, gold folding clasp, steel Caliber : B01 , BCA01     10300.0         1      6386.0        6386.0\n","4  UB0136251L1S1  20117962  SUPER CHRONOMAT B01 44 12800.00 1 7,936.00 7,936.00 cal. Chronometer B01, 13 1/4''', 47J steel case, black ceramic ring, crystal back Green, black subdials, markers ROULEAUX Rubber strap, black folding clasp, steel Caliber : B01 , BCA01 Net Weight OR ROUGE 18CT 5N : 17.270 G Total Diamonds Weight (CT) : 0.000     12800.0         1      7936.0        7936.0\n","------------------------------------------\n","\n","✅ Done—Excel file 'invoice_extracted_data.xlsx' created. Download your Excel below.\n"]},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_763c55b4-b576-49d2-bc1c-41aa5f0ad30d\", \"invoice_extracted_data.xlsx\", 5650)"]},"metadata":{}}],"source":["# Install necessary libraries\n","# Edited and Created by Cesar Tobar, Updated by Gemini\n","\n","!pip install pdfplumber pandas openpyxl\n","\n","import io\n","import re\n","import pandas as pd\n","import pdfplumber\n","from google.colab import files\n","\n","def extract_text_from_pdf(pdf_file_content_arg):\n","    \"\"\"Extracts text from all pages of a PDF file.\"\"\"\n","    text_parts = []\n","    try:\n","        with pdfplumber.open(io.BytesIO(pdf_file_content_arg)) as pdf:\n","            for page in pdf.pages:\n","                page_text = page.extract_text()\n","                text_parts.append(page_text or \"\")\n","        full_text = \"\\n\".join(text_parts).strip()\n","        print(f\"Successfully extracted text from PDF. Total length: {len(full_text)} characters.\")\n","        return full_text\n","    except Exception as e:\n","        print(f\"Error reading PDF with pdfplumber: {e}\")\n","        return None\n","\n","def clean_text(text):\n","    \"\"\"Cleans extracted text by removing excessive newlines and spaces.\"\"\"\n","    if not text:\n","        return \"\"\n","    text = text.replace('\"', '').strip()\n","    text = re.sub(r'\\n+', '\\n', text)\n","    text = re.sub(r' +', ' ', text)\n","    return text.strip()\n","\n","def clean_price(price_str):\n","    \"\"\"Cleans price string (handles apostrophes and commas) and converts to float.\"\"\"\n","    if not price_str:\n","        return 0.0\n","    v = price_str.replace(\"'\", \"\").replace(\",\", \"\")\n","    if v.count('.') > 1:\n","        parts = v.split('.')\n","        v = \"\".join(parts[:-1]) + \".\" + parts[-1]\n","    try:\n","        return float(v)\n","    except ValueError:\n","        return 0.0\n","\n","def parse_layout_1(pdf_text):\n","    \"\"\"\n","    Parses PDF text based on layout detection using \"of origin\" keyword.\n","    Handles multiple serial numbers on a single line and splits them into distinct rows.\n","    \"\"\"\n","    items = []\n","    lines = pdf_text.splitlines()\n","    print(f\"\\n--- Starting to parse using Layout 1 ('of origin' based) ---\")\n","\n","    item_start_regex = re.compile(\n","        r\"^([A-Z0-9]{6,})\\s+(.*?)\\s+(\\d+)\\s+([\\d\\'.,]+)\\s+([\\d\\'.,]+)$\"\n","    )\n","    # Updated Regex to capture multiple serials separated by spaces\n","    serial_regex_l1 = re.compile(r\"Serial No\\.\\s*([0-9\\s]+)\", re.IGNORECASE)\n","\n","    end_of_items_patterns = [\n","        re.compile(r\"^\\s*TOTAL WATCHES.*$\"),\n","        re.compile(r\"^\\s*Total\\s+USD.*$\"),\n","        re.compile(r\"^\\s*Payment Reference\\s*$\"),\n","        re.compile(r\"^\\s*Summary of customs.*$\"),\n","        re.compile(r\"^\\s*Custom tariff.*$\")\n","    ]\n","\n","    skip_desc_patterns = [\n","        re.compile(r\"^\\s*\\d+/\\d+\\s*$\"),\n","        re.compile(r\"^\\s*Breitling SA.*$\"),\n","        re.compile(r\"^\\s*Telephone.*$\"),\n","        re.compile(r\"^\\s*BREITLING\\.COM\\s*$\"),\n","        re.compile(r\"^\\s*Product Description.*$\"),\n","        re.compile(r\"^\\s*Weight of origin\\s*$\"),\n","        re.compile(r\"^\\s*(?:Movement|Bracelet|Case|Caliber|Net Weight|Total Diamonds|Water Resistance)\\b.*\", re.IGNORECASE),\n","        re.compile(r\"^\\s*[\\d\\'.,]+\\s*$\")\n","    ]\n","\n","    i = 0\n","    while i < len(lines):\n","        line = lines[i].strip()\n","        if not line or any(p.match(line) for p in end_of_items_patterns) or any(p.match(line) for p in skip_desc_patterns):\n","            i += 1\n","            continue\n","\n","        match = item_start_regex.match(line)\n","        if match:\n","            style = match.group(1)\n","            desc_raw = match.group(2)\n","            quantity_val = int(match.group(3))\n","            unit_price_val = clean_price(match.group(4))\n","            total_amount_val = clean_price(match.group(5))\n","\n","            desc_clean = re.sub(r\"\\s+(?:\\d{1,4}\\.\\d{3}\\s*G|\\d{4}\\.\\d{4}.*).*$\", \"\", desc_raw, flags=re.IGNORECASE).strip()\n","\n","            current_serials = []\n","            desc_parts = [desc_clean]\n","\n","            sm = serial_regex_l1.search(line)\n","            if sm:\n","                current_serials.extend(sm.group(1).split())\n","                desc_parts[0] = serial_regex_l1.sub('', desc_parts[0]).strip()\n","\n","            j = i + 1\n","            while j < len(lines):\n","                cont_line = lines[j].strip()\n","                if not cont_line:\n","                    j += 1\n","                    continue\n","\n","                if item_start_regex.match(cont_line) or any(p.match(cont_line) for p in end_of_items_patterns):\n","                    break\n","\n","                sm_cont = serial_regex_l1.search(cont_line)\n","                if sm_cont:\n","                    current_serials.extend(sm_cont.group(1).split())\n","                    cont_line_clean = serial_regex_l1.sub('', cont_line).strip()\n","                    if cont_line_clean and not any(p.match(cont_line_clean) for p in skip_desc_patterns):\n","                        desc_parts.append(cont_line_clean)\n","                    j += 1\n","                    continue\n","\n","                if any(p.match(cont_line) for p in skip_desc_patterns):\n","                    j += 1\n","                    continue\n","\n","                desc_parts.append(cont_line)\n","                j += 1\n","\n","            full_description = \" \".join(d for d in desc_parts if d).strip()\n","            full_description = re.sub(r'\\s+', ' ', full_description)\n","\n","            # If no serials were found at all, assign N/A\n","            if not current_serials:\n","                current_serials = [\"N/A\"]\n","\n","            # Loop through however many serials we captured and create a row for each\n","            for serial in current_serials:\n","                # If we are splitting a multi-quantity item, adjust the Qty to 1 and Total to the Unit Price\n","                is_split = len(current_serials) > 1\n","\n","                items.append({\n","                    \"Style\": style,\n","                    \"Serial\": serial.strip(),\n","                    \"Description\": full_description,\n","                    \"List Price\": \"\",\n","                    \"Quantity\": 1 if is_split else quantity_val,\n","                    \"Unit Price\": unit_price_val,\n","                    \"Total Amount\": unit_price_val if is_split else total_amount_val,\n","                })\n","            i = j\n","        else:\n","            i += 1\n","\n","    print(f\"--- Finished parsing with Layout 1. Found {len(items)} items. ---\")\n","    return items\n","\n","def parse_layout_2(full_text_from_pdf):\n","    # [Unchanged from previous version - omitted for brevity in response,\n","    #  but keep the code exactly as it was in your Colab script]\n","    \"\"\"\n","    Parses PDF text based on layout detection using \"List Price\" keyword.\n","    \"\"\"\n","    print(f\"\\n--- Starting to parse using Layout 2 ('List Price' based) ---\")\n","    current_text = full_text_from_pdf\n","    token = \"Product Description Custom Tariff\"\n","    if token in current_text:\n","        current_text = current_text.split(token,1)[1]\n","\n","    style_pat = re.compile(r'\\b(?=[A-Z0-9]*\\d)[A-Z0-9]{10,}\\b')\n","    style_matches = list(style_pat.finditer(current_text))\n","    records = []\n","    for i, m in enumerate(style_matches):\n","        style = m.group()\n","        start = m.end()\n","        end = style_matches[i+1].start() if i+1 < len(style_matches) else len(current_text)\n","        block = current_text[start:end]\n","\n","        sm = re.search(r\"Serial Nr: Serial No\\.\\s*(\\d+)\", block)\n","        serial = sm.group(1) if sm else \"\"\n","\n","        desc_parts = block.split(\"Serial Nr:\",1)\n","        desc_text = desc_parts[0].strip()\n","        description = \" \".join(desc_text.split())\n","\n","        price_pat = re.compile(\n","            r'(?P<list_price>\\d+(?:,\\d{3})*\\.\\d{2})\\s+'\n","            r'(?P<quantity>\\d+)\\s+'\n","            r'(?P<unit_price>\\d+(?:,\\d{3})*\\.\\d{2})\\s+'\n","            r'(?P<total_amount>\\d+(?:,\\d{3})*\\.\\d{2})'\n","        )\n","        pm = price_pat.search(block)\n","        list_price_val, quantity_val, unit_price_val, total_amount_val = None, None, None, None\n","        if pm:\n","            try:\n","                list_price_val   = float(pm.group('list_price').replace(\",\", \"\"))\n","                quantity_val     = int(pm.group('quantity'))\n","                unit_price_val   = float(pm.group('unit_price').replace(\",\", \"\"))\n","                total_amount_val = float(pm.group('total_amount').replace(\",\", \"\"))\n","            except Exception as e_price:\n","                print(f\"    WARNING (Layout 2): Error parsing prices for Style {style}.\")\n","\n","        if style:\n","            records.append({\n","                \"Style\": style, \"Serial\": serial, \"Description\": description,\n","                \"List Price\": list_price_val, \"Quantity\": quantity_val,\n","                \"Unit Price\": unit_price_val, \"Total Amount\":total_amount_val\n","            })\n","    print(f\"--- Finished parsing with Layout 2. Found {len(records)} items. ---\")\n","    return records\n","\n","def parse_layout_3(pdf_text):\n","    # [Unchanged from previous version - omitted for brevity in response,\n","    #  but keep the code exactly as it was in your Colab script]\n","    \"\"\"\n","    Parses PDF text based on layout detection using \"Cantidad Unidad Clave\" or \"FACTURA\" keyword.\n","    \"\"\"\n","    items = []\n","    lines = pdf_text.splitlines()\n","    print(f\"\\n--- Starting to parse using Layout 3 (Spanish Invoice) ---\")\n","\n","    item_line_l3_regex = re.compile(\n","        r\"^(\\d+)\\s+pz\\s+([A-Z0-9]{10,})\\s+(.+?)\\s+([\\d\\.]+)\\s+([\\d,]+\\.\\d{2})\\s+([\\d,]+\\.\\d{2})$\"\n","    )\n","    pedimento_regex = re.compile(r\"Pedimento aduanal:[\\s\\d/]+\", re.IGNORECASE)\n","    serial_only_line_regex = re.compile(r\"^\\d{7,}$\")\n","\n","    stopper_patterns_l3 = [\n","        re.compile(r\"^Cantidad Unidad Clave\", re.IGNORECASE),\n","        re.compile(r\"^Subtotal\", re.IGNORECASE),\n","        re.compile(r\"^Descuento\", re.IGNORECASE),\n","        re.compile(r\"^IVA\", re.IGNORECASE),\n","        re.compile(r\"^I\\.V\\.A\\.\", re.IGNORECASE),\n","        re.compile(r\"^Total\", re.IGNORECASE),\n","        re.compile(r\"^Este documento es una representación impresa de un CFDI\", re.IGNORECASE),\n","        re.compile(r\"^Folio fiscal:\", re.IGNORECASE),\n","        re.compile(r\"^Enition por\", re.IGNORECASE),\n","        re.compile(r\"^Emitido por\", re.IGNORECASE)\n","    ]\n","\n","    i = 0\n","    while i < len(lines):\n","        line = lines[i].strip()\n","        is_stopper_line = any(p.match(line) for p in stopper_patterns_l3)\n","        if is_stopper_line:\n","            i += 1\n","            continue\n","\n","        match = item_line_l3_regex.match(line)\n","        if match:\n","            quantity_str = match.group(1)\n","            style = match.group(2)\n","            initial_desc_part = match.group(3).strip()\n","            unit_price_str = match.group(5)\n","            total_amount_str = match.group(6)\n","\n","            try:\n","                quantity_val = int(quantity_str)\n","                unit_price_val = float(unit_price_str.replace(',', ''))\n","                total_amount_val = float(total_amount_str.replace(',', ''))\n","            except ValueError as e:\n","                i += 1\n","                continue\n","\n","            current_serial = \"N/A\"\n","            description_continuation_start_index = i + 1\n","\n","            if (i + 1) < len(lines):\n","                next_line_content = lines[i + 1].strip()\n","                if serial_only_line_regex.fullmatch(next_line_content):\n","                    current_serial = next_line_content\n","                    description_continuation_start_index = i + 2\n","\n","            description_cleaned_initial = pedimento_regex.sub('', initial_desc_part).strip()\n","            description_cleaned_initial = re.sub(r'\\s+\\d{2}/\\d{2}/\\d{4}$', '', description_cleaned_initial).strip()\n","            description_cleaned_initial = \" \".join(description_cleaned_initial.split())\n","\n","            description_parts_l3 = [description_cleaned_initial] if description_cleaned_initial else []\n","\n","            j = description_continuation_start_index\n","            while j < len(lines):\n","                cont_line_raw = lines[j].strip()\n","                if not cont_line_raw:\n","                    j+=1\n","                    continue\n","                if item_line_l3_regex.match(cont_line_raw) or any(p.match(cont_line_raw) for p in stopper_patterns_l3):\n","                    break\n","\n","                desc_cont_cleaned = pedimento_regex.sub('', cont_line_raw).strip()\n","                desc_cont_cleaned = re.sub(r'\\s+\\d{2}/\\d{2}/\\d{4}\\s+\\d+$', '', desc_cont_cleaned).strip()\n","                desc_cont_cleaned = \" \".join(desc_cont_cleaned.split())\n","\n","                if desc_cont_cleaned:\n","                    description_parts_l3.append(desc_cont_cleaned)\n","                j += 1\n","\n","            full_description = \" \".join(d for d in description_parts_l3 if d).strip()\n","\n","            items.append({\n","                \"Style\": style,\n","                \"Serial\": current_serial,\n","                \"Description\": full_description,\n","                \"List Price\": \"\",\n","                \"Quantity\": quantity_val,\n","                \"Unit Price\": unit_price_val,\n","                \"Total Amount\": total_amount_val,\n","            })\n","            i = j\n","        else:\n","            i += 1\n","\n","    print(f\"--- Finished parsing with Layout 3. Found {len(items)} items. ---\")\n","    return items\n","\n","def main():\n","    print(\"Please upload your PDF file.\")\n","    uploaded = files.upload()\n","\n","    if not uploaded:\n","        print(\"No file uploaded. Exiting.\")\n","        return\n","\n","    file_name = list(uploaded.keys())[0]\n","    file_content = uploaded[file_name]\n","\n","    print(f\"\\nProcessing '{file_name}'...\")\n","\n","    pdf_text_raw = extract_text_from_pdf(file_content)\n","    if not pdf_text_raw:\n","        print(\"Could not extract text from PDF. Exiting.\")\n","        return\n","\n","    extracted_data = []\n","\n","    if \"Cantidad Unidad Clave\" in pdf_text_raw:\n","        print(\"INFO: Detected Layout 3 (Spanish Invoice - based on 'Cantidad Unidad Clave' keyword).\")\n","        extracted_data = parse_layout_3(pdf_text_raw)\n","    elif \"FACTURA\" in pdf_text_raw:\n","        print(\"INFO: Detected Layout 3 (Spanish Invoice - based on 'FACTURA' keyword).\")\n","        extracted_data = parse_layout_3(pdf_text_raw)\n","    elif \"List Price\" in pdf_text_raw:\n","        print(\"INFO: Detected Layout 2 (English/Other - based on 'List Price' keyword).\")\n","        extracted_data = parse_layout_2(pdf_text_raw)\n","    elif \"of origin\" in pdf_text_raw:\n","        print(\"INFO: Detected Layout 1 (English Invoice - based on 'of origin' keyword).\")\n","        extracted_data = parse_layout_1(pdf_text_raw)\n","    else:\n","        print(\"WARNING: Unrecognized invoice layout. None of the known keywords ('Cantidad Unidad Clave', 'FACTURA', 'List Price', 'of origin') found. Cannot process.\")\n","        return\n","\n","    if not extracted_data:\n","        print(\"No data could be parsed from the PDF with the detected layout.\")\n","        return\n","\n","    print(f\"\\nSuccessfully parsed {len(extracted_data)} items from PDF.\")\n","\n","    df = pd.DataFrame(extracted_data)\n","\n","    columns_ordered = [\"Style\", \"Serial\", \"Description\", \"List Price\", \"Quantity\", \"Unit Price\", \"Total Amount\"]\n","\n","    for col in columns_ordered:\n","        if col not in df.columns:\n","            df[col] = pd.NA\n","    df = df[columns_ordered]\n","\n","    print(\"\\n--- Parsed Data Preview (First 5 rows) ---\")\n","    print(df.head().to_string())\n","    print(\"------------------------------------------\\n\")\n","\n","    out_filename = \"invoice_extracted_data.xlsx\"\n","    try:\n","        df.to_excel(out_filename, index=False, engine=\"openpyxl\")\n","        print(f\"✅ Done—Excel file '{out_filename}' created. Download your Excel below.\")\n","        files.download(out_filename)\n","    except Exception as e:\n","        print(f\"Error saving or downloading Excel file: {e}\")\n","\n","if __name__ == \"__main__\":\n","    main()"]}]}